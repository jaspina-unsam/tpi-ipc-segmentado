install.packages("eph")
library(eph)
glimpse(base_individual)
library(dplyr)
base_individual <- get_microdata(
year=2023,
trimester=3,
type="individual"
)
glimpse(base_individual)
View(base_individual)
library(tidyverse)
# Ingreso mediano por categoría ocupacional, ponderado
base_individual %>%
filter(P21 > 0) %>%
group_by(CAT_OCUP) %>%
summarise(
ingreso_mediano = weighted.median(P21, PONDERA),
n_ponderado = sum(PONDERA)
)
install.packages("tidyverse")
library(tidyverse)
# Ingreso mediano por categoría ocupacional, ponderado
base_individual %>%
filter(P21 > 0) %>%
group_by(CAT_OCUP) %>%
summarise(
ingreso_mediano = weighted.median(P21, PONDERA),
n_ponderado = sum(PONDERA)
)
# Para calcular medianas ponderadas (weightedMedian) usamos el paquete matrixStats
install.packages("matrixStats")
# Ingreso mediano por categoría ocupacional, ponderado
base_individual %>%
filter(P21 > 0) %>%
group_by(CAT_OCUP) %>%
summarise(
ingreso_mediano = matrixStats::weightedMedian(P21, w = PONDERA, na.rm = TRUE),
n_ponderado = sum(PONDERA)
)
