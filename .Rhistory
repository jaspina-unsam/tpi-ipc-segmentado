library(eph)
library(tidyverse)
eph_ind_2025_3 <- get_microdata(
year = 2025,
trimester = 3,
type = "individual"
)
vars_select <- c(
"ANO4",
"TRIMESTRE",
"CODUSU",
"NRO_HOGAR",
"COMPONENTE",
"AGLOMERADO",
"REGION",
"ESTADO",
"CAT_OCUP",
"CH04",
"CH06",
"NIVEL_ED",
"PP04B_COD",
"PP04D_COD",
"P21",
"ITF",
"PONDERA",
"PONDIIO",
"PONDIH"
)
eph_ind_2025_3_select <- get_microdata(
year = 2025,
trimester = 3,
vars = vars_select,
type = "individual"
)
df <- eph_ind_2025_3_select %>%
organize_labels()
df <- df %>%
organize_cno()
df <- df %>%
organize_caes()
calculate_tabulates(
base = df,
x = "JERARQUIA",
y = "CH04",
weights = "PONDERA",
add.totals = "both"
)
calculate_tabulates(
base = df,
x = "caes_seccion_label",
y = "NIVEL_ED",
weights = "PONDERA",
add.percentage = "row"
)
tasas <- df %>%
group_by(AGLOMERADO) %>%
summarize(tasa_actividad = sum(PONDERA[ESTADO==1])/sum(PONDERA)) %>%
mutate(AGLOMERADO = as.numeric(AGLOMERADO))
map_agglomerates(.data = tasas,
agglomerates = "AGLOMERADO",
indicator = "tasa_actividad")
tasas <- df %>%
group_by(AGLOMERADO) %>%
summarize(tasa_actividad = sum(PONDERA[ESTADO==1])/sum(PONDERA)) %>%
ungroup() %>% # <--- IMPORTANTE: quitamos la estructura de grupo
mutate(AGLOMERADO = as.integer(as.character(AGLOMERADO))) # Doble conversión para limpiar etiquetas
map_agglomerates(.data = tasas,
agglomerates = "AGLOMERADO",
indicator = "tasa_actividad")
tasas <- df %>%
group_by(AGLOMERADO) %>%
summarize(tasa_actividad = sum(PONDERA[ESTADO==1])/sum(PONDERA)) %>%
mutate(AGLOMERADO = as.integer(as.character(AGLOMERADO))) # Doble conversión para limpiar etiquetas
map_agglomerates(.data = tasas,
agglomerates = "AGLOMERADO",
indicator = "tasa_actividad")
tasas <- df %>%
group_by(AGLOMERADO) %>%
summarize(tasa_actividad = sum(PONDERA[ESTADO==1])/sum(PONDERA))
map_agglomerates(.data = tasas,
agglomerates = "AGLOMERADO",
indicator = "tasa_actividad")
